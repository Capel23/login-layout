<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mangup_bg_light"
    tools:context=".ProductDetailActivity">

    <!-- Barra superior -->
    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/icon_teal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Volver"
            android:scaleType="centerInside"
            app:tint="@color/icon_gold" />

        <TextView
            android:id="@+id/headerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Detalle del Producto"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/icon_cream"
            android:layout_marginStart="16dp" />

        <ImageButton
            android:id="@+id/cartButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_agenda"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Ver carrito"
            android:scaleType="centerInside"
            app:tint="@color/icon_gold" />

    </androidx.appcompat.widget.LinearLayoutCompat>

    <!-- Línea dorada decorativa -->
    <View
        android:id="@+id/goldLine"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@color/icon_gold"
        app:layout_constraintTop_toBottomOf="@id/headerLayout" />

    <!-- ScrollView para el contenido -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/goldLine"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Imagen del producto -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/mangup_cream_soft"
                android:layout_marginBottom="20dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/productImage"
                        android:layout_width="match_parent"
                        android:layout_height="280dp"
                        android:scaleType="centerCrop"
                        android:contentDescription="Imagen del producto"
                        android:src="@drawable/ic_launcher_background" />

                    <!-- Borde inferior dorado -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_gravity="bottom"
                        android:background="@color/icon_gold" />

                </FrameLayout>

            </androidx.cardview.widget.CardView>

            <!-- Card de información -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/mangup_cream_soft"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Nombre del producto -->
                    <TextView
                        android:id="@+id/productName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nombre del Producto"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/icon_dark_teal"
                        android:layout_marginBottom="8dp" />

                    <!-- Precio del producto -->
                    <TextView
                        android:id="@+id/productPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="$0.00"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/icon_crimson"
                        android:layout_marginBottom="16dp" />

                    <!-- Separador dorado -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@color/icon_gold"
                        android:layout_marginBottom="16dp" />

                    <!-- Título Descripción -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Descripción"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/icon_teal"
                        android:layout_marginBottom="8dp" />

                    <!-- Descripción del producto -->
                    <TextView
                        android:id="@+id/productDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Descripción del producto..."
                        android:textSize="15sp"
                        android:textColor="@color/gray_dark"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Selector de cantidad -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/mangup_cream_soft">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cantidad:"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/icon_dark_teal" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginStart="16dp"
                        android:background="@drawable/quantity_selector_background"
                        android:padding="4dp">

                        <ImageButton
                            android:id="@+id/decreaseButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:drawable/ic_media_previous"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Disminuir cantidad"
                            app:tint="@color/icon_crimson" />

                        <TextView
                            android:id="@+id/quantityText"
                            android:layout_width="56dp"
                            android:layout_height="wrap_content"
                            android:text="1"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/icon_dark_teal"
                            android:gravity="center" />

                        <ImageButton
                            android:id="@+id/increaseButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@android:drawable/ic_media_next"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="Aumentar cantidad"
                            app:tint="@color/icon_teal" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <!-- Barra inferior con botón añadir al carrito -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/icon_teal"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Total -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total"
                android:textSize="14sp"
                android:textColor="@color/icon_cream" />

            <TextView
                android:id="@+id/totalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0.00"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/icon_gold" />

        </LinearLayout>

        <!-- Botón añadir al carrito -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/addToCartButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1.5"
            android:text="Añadir al Carrito"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/icon_cream"
            app:backgroundTint="@color/icon_red_bg"
            app:cornerRadius="10dp"
            app:icon="@android:drawable/ic_input_add"
            app:iconTint="@color/icon_gold"
            app:iconGravity="textStart" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

