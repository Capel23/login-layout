<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mangup_bg_light"
    tools:context=".HomeActivity">

    <!-- Barra superior con mensaje de bienvenida -->
    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/icon_teal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/welcomeText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="¡Bienvenido!"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/icon_cream" />

        <!-- Botón de carrito con badge -->
        <FrameLayout
            android:id="@+id/cartButtonContainer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/cartButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_cart"
                android:contentDescription="Ver carrito"
                android:scaleType="centerInside"
                app:tint="@color/icon_gold" />

            <!-- Badge contador de items -->
            <TextView
                android:id="@+id/cartBadge"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/cart_badge_background"
                android:gravity="center"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </FrameLayout>

        <ImageButton
            android:id="@+id/logoutButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Logout"
            android:scaleType="centerInside"
            app:tint="@color/icon_gold" />

    </androidx.appcompat.widget.LinearLayoutCompat>

    <!-- Decoración con línea dorada -->
    <View
        android:id="@+id/goldLine"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@color/icon_gold"
        app:layout_constraintTop_toBottomOf="@id/headerLayout" />

    <!-- Título de Productos -->
    <TextView
        android:id="@+id/productsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nuestros Productos"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/icon_dark_teal"
        android:layout_marginStart="16dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/goldLine"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Línea decorativa bajo el título -->
    <View
        android:id="@+id/titleUnderline"
        android:layout_width="80dp"
        android:layout_height="3dp"
        android:background="@color/icon_crimson"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/productsTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- RecyclerView para mostrar productos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/productsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/titleUnderline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
